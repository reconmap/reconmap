    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Agent",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/agent/cmd/reconmapd/main.go",
            "args": [
                "run"
            ],
            "env": {}
        },
        {
            "name": "Launch Runner",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/runner/cmd/rmap/main.go",
            "args": [
                "command",
                "run",
                "-pid",
                "1",
                "-cuid",
                "2"
            ],
            "env": {}
        }
    ]
}