root = true

[*]
indent_style = space
indent_size = 4
max_line_length = 120

end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[package.json]
indent_size = 2

[.eslintrc]
indent_size = 2

[*.{css}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
